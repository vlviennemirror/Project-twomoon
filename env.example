# =============================================================================
# Two Moon Ecosystem — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# --- CockroachDB (Serverless) -----------------------------------------------
DATABASE_URL=postgresql://username:password@host.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full

# --- Redis (Upstash / Railway) -----------------------------------------------
REDIS_URL=rediss://default:password@endpoint.upstash.io:6379

# --- Discord OAuth2 (Web Hub) -----------------------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://your-domain.com/auth/callback

# --- Discord Server --------------------------------------------------------
TWOMOON_GUILD_ID=

# --- Role-Based Access Control (comma-separated Discord Role IDs) -----------
AUTHORIZED_ROLE_IDS=111111111111111111,222222222222222222
OWNER_ROLE_IDS=111111111111111111
ADMIN_ROLE_IDS=222222222222222222

# --- JWT Session ------------------------------------------------------------
JWT_SECRET_KEY=generate-a-strong-random-string-minimum-32-chars

# --- Bot Token Encryption (AES-256-GCM) ------------------------------------
# Generate with: python -c "from shared_lib.encryption import generate_master_key; print(generate_master_key())"
TWOMOON_MASTER_KEY=

# --- Web Hub ----------------------------------------------------------------
TWOMOON_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_SUCCESS_URL=/dashboard
FRONTEND_FAILURE_URL=/login?error=forbidden
LOG_LEVEL=INFO

# --- AlmaLinux Agent --------------------------------------------------------
# Override Python path if using a virtualenv on the VPS
# TWOMOON_PYTHON=/opt/twomoon/venv/bin/python
